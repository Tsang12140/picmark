<Window x:Class="PicMark.TextInputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="输入文字" Width="440" Height="240"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        ShowInTaskbar="False">
    <StackPanel Margin="20">
        <TextBlock Text="请输入要添加的文字：" FontSize="16" Margin="0,0,0,10"/>
        <TextBox x:Name="TxtInput" FontSize="22" Height="80" AcceptsReturn="True" TextWrapping="Wrap"
                 VerticalScrollBarVisibility="Auto" KeyDown="TxtInput_KeyDown"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="取消" Width="100" Height="44" Margin="0,0,10,0" FontSize="16" Click="BtnCancel_Click"/>
            <Button Content="确定" Width="100" Height="44" FontSize="16" FontWeight="Bold"
                    Background="#FF4CAF50" Foreground="White" Click="BtnOk_Click"/>
        </StackPanel>
    </StackPanel>
</Window>
