<Window x:Class="PicMark.TextInputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="输入文字" Width="480" Height="320"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="#FFF6F7FB"
        FontFamily="Segoe UI, Microsoft YaHei UI, Microsoft YaHei">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Height" Value="38"/>
            <Setter Property="MinWidth" Value="92"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Margin" Value="8,0,0,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#FFD7DCE5"/>
            <Setter Property="Background" Value="White"/>
        </Style>
    </Window.Resources>
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="TitleText" Text="添加文字" FontSize="20" FontWeight="SemiBold" Foreground="#FF1F2329"/>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,16,0,10">
            <TextBlock Text="字号" VerticalAlignment="Center" FontSize="14" Foreground="#FF4B5563" Margin="0,0,10,0"/>
            <ComboBox x:Name="FontSizeBox" Width="132" Height="34" SelectionChanged="FontSizeBox_SelectionChanged">
                <ComboBoxItem Content="小 24" Tag="24"/>
                <ComboBoxItem Content="中 36" Tag="36"/>
                <ComboBoxItem Content="大 52" Tag="52"/>
                <ComboBoxItem Content="特大 72" Tag="72"/>
            </ComboBox>
            <TextBlock Text="Ctrl+Enter 完成，输入后可直接拖动" VerticalAlignment="Center" FontSize="12.5"
                       Foreground="#FF6B7280" Margin="16,0,0,0"/>
        </StackPanel>

        <Border Grid.Row="2" Background="White" BorderBrush="#FFD7DCE5" BorderThickness="1" CornerRadius="8">
            <TextBox x:Name="TxtInput" FontSize="36" BorderThickness="0" Padding="12" AcceptsReturn="True"
                     TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" KeyDown="TxtInput_KeyDown"/>
        </Border>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
            <Button Content="取消" Click="BtnCancel_Click"/>
            <Button Content="完成" FontWeight="SemiBold" Background="#FF0F8B4C" Foreground="White"
                    BorderBrush="#FF0F8B4C" Click="BtnOk_Click"/>
        </StackPanel>
    </Grid>
</Window>
