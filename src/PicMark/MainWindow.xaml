                                            <Viewbox Width="48" Height="38">
                                                <Canvas Width="64" Height="46">
                                                    <Border Canvas.Left="8" Canvas.Top="8" Width="48" Height="30"
                                                            Background="#FF232A36" BorderBrush="#FFB9BEC7" BorderThickness="1" CornerRadius="5">
                                                        <TextBlock Text="LOGO" FontSize="11" FontWeight="Bold" Foreground="#FFF4F4F5"
                                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                </Canvas>
                                            </Viewbox>
                                            <TextBlock Text="图片 Logo" FontSize="11" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                </UniformGrid>

                                <StackPanel x:Name="WatermarkParametersPanel" Visibility="Collapsed">
                                    <TextBlock x:Name="WatermarkTextLabel" Text="水印文字（可按 Enter 手动分行）" Style="{StaticResource SectionLabel}"/>
                                    <TextBox x:Name="WatermarkTextBox" Height="72" MaxLength="120"
                                             AcceptsReturn="True" TextWrapping="Wrap"
                                             Background="#FF2E2E2E" Foreground="White" BorderBrush="#FF606060"
                                             VerticalScrollBarVisibility="Auto" Padding="8,6"
                                             TextChanged="WatermarkOption_Changed"/>

                                    <TextBlock x:Name="WatermarkFontLabel" Text="字体" Style="{StaticResource SectionLabel}"/>
                                    <UniformGrid x:Name="WatermarkFontPanel" Columns="4">
                                        <Button x:Name="WatermarkFontYaHeiBtn" Style="{StaticResource ToolButton}" Height="32" Padding="3" Tag="Microsoft YaHei UI" Click="WatermarkFont_Click"><TextBlock Text="雅黑" FontSize="11"/></Button>
                                        <Button x:Name="WatermarkFontSimSunBtn" Style="{StaticResource ToolButton}" Height="32" Padding="3" Tag="SimSun" Click="WatermarkFont_Click"><TextBlock Text="宋体" FontSize="11"/></Button>
                                        <Button x:Name="WatermarkFontSimHeiBtn" Style="{StaticResource ToolButton}" Height="32" Padding="3" Tag="SimHei" Click="WatermarkFont_Click"><TextBlock Text="黑体" FontSize="11"/></Button>
                                        <Button x:Name="WatermarkFontKaiTiBtn" Style="{StaticResource ToolButton}" Height="32" Padding="3" Tag="KaiTi" Click="WatermarkFont_Click"><TextBlock Text="楷体" FontSize="11"/></Button>
                                    </UniformGrid>

                                    <Grid x:Name="WatermarkFontSizeHeader" Margin="0,10,0,3">
                                        <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="46"/><ColumnDefinition Width="52"/></Grid.ColumnDefinitions>
                                        <TextBlock Text="字号" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                        <TextBlock x:Name="WatermarkFontSizeValue" Grid.Column="1" Foreground="White" TextAlignment="Right" VerticalAlignment="Center"/>
                                        <Button Grid.Column="2" Style="{StaticResource WatermarkSecondaryButton}" Height="24" Padding="6,0" Margin="6,0,0,0" Tag="FontSize" Click="WatermarkReset_Click"><TextBlock Text="重置" FontSize="11"/></Button>
                                    </Grid>
                                    <Grid x:Name="WatermarkFontSizePanel"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="46"/></Grid.ColumnDefinitions><Slider x:Name="WatermarkFontSizeSlider" Minimum="12" Maximum="72" Value="28" TickFrequency="2" IsSnapToTickEnabled="True" ValueChanged="WatermarkOption_Changed"/><Button x:Name="WatermarkBoldBtn" Grid.Column="1" Style="{StaticResource ToolButton}" Height="32" Margin="8,0,0,0" Click="WatermarkBold_Click"><TextBlock Text="B" FontWeight="Bold" FontSize="16"/></Button></Grid>

                                    <Grid Margin="0,10,0,3"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="46"/><ColumnDefinition Width="52"/></Grid.ColumnDefinitions><TextBlock Text="不透明度" Foreground="{StaticResource TextSecondaryBrush}"/><TextBlock x:Name="WatermarkOpacityValue" Grid.Column="1" Foreground="White" TextAlignment="Right"/><Button Grid.Column="2" Style="{StaticResource WatermarkSecondaryButton}" Height="24" Padding="6,0" Margin="6,0,0,0" Tag="Opacity" Click="WatermarkReset_Click"><TextBlock Text="重置" FontSize="11"/></Button></Grid>
                                    <Slider x:Name="WatermarkOpacitySlider" Minimum="5" Maximum="100" Value="20" TickFrequency="5" ValueChanged="WatermarkOption_Changed"/>

                                    <Grid Margin="0,10,0,3"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="46"/><ColumnDefinition Width="52"/></Grid.ColumnDefinitions><TextBlock Text="角度" Foreground="{StaticResource TextSecondaryBrush}"/><TextBlock x:Name="WatermarkAngleValue" Grid.Column="1" Foreground="White" TextAlignment="Right"/><Button Grid.Column="2" Style="{StaticResource WatermarkSecondaryButton}" Height="24" Padding="6,0" Margin="6,0,0,0" Tag="Angle" Click="WatermarkReset_Click"><TextBlock Text="重置" FontSize="11"/></Button></Grid>
                                    <Slider x:Name="WatermarkAngleSlider" Minimum="-90" Maximum="90" Value="0" TickFrequency="1" ValueChanged="WatermarkOption_Changed"/>

                                    <Grid x:Name="WatermarkSpacingHeader" Margin="0,10,0,3"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="46"/><ColumnDefinition Width="52"/></Grid.ColumnDefinitions><TextBlock Text="间距（密度）" Foreground="{StaticResource TextSecondaryBrush}"/><TextBlock x:Name="WatermarkSpacingValue" Grid.Column="1" Foreground="White" TextAlignment="Right"/><Button Grid.Column="2" Style="{StaticResource WatermarkSecondaryButton}" Height="24" Padding="6,0" Margin="6,0,0,0" Tag="Spacing" Click="WatermarkReset_Click"><TextBlock Text="重置" FontSize="11"/></Button></Grid>
                                    <Slider x:Name="WatermarkSpacingSlider" Minimum="80" Maximum="400" Value="204" TickFrequency="4" IsSnapToTickEnabled="True" ValueChanged="WatermarkOption_Changed"/>

                                    <Grid x:Name="WatermarkOffsetHeader" Margin="0,10,0,3"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="46"/><ColumnDefinition Width="52"/></Grid.ColumnDefinitions><TextBlock Text="平铺偏移" Foreground="{StaticResource TextSecondaryBrush}"/><TextBlock x:Name="WatermarkOffsetValue" Grid.Column="1" Foreground="White" TextAlignment="Right"/><Button Grid.Column="2" Style="{StaticResource WatermarkSecondaryButton}" Height="24" Padding="6,0" Margin="6,0,0,0" Tag="Offset" Click="WatermarkReset_Click"><TextBlock Text="重置" FontSize="11"/></Button></Grid>
                                    <Slider x:Name="WatermarkOffsetSlider" Minimum="-400" Maximum="400" Value="0" TickFrequency="1" ValueChanged="WatermarkOption_Changed"/>

                                    <StackPanel x:Name="LogoParametersPanel" Visibility="Collapsed" Margin="0,12,0,0">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition/>
                                                <ColumnDefinition Width="94"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="图片素材" Style="{StaticResource SectionLabel}" Margin="0" VerticalAlignment="Center"/>
                                            <Button Grid.Column="1" Style="{StaticResource WatermarkSecondaryButton}" Height="30" Margin="0" Click="BtnAddLogoWatermark_Click">
                                                <TextBlock Text="添加 / 更换" FontSize="12"/>
                                            </Button>
                                        </Grid>
                                        <TextBlock Text="最近 Logo" Style="{StaticResource SectionLabel}" Margin="0,10,0,6"/>
                                        <WrapPanel x:Name="RecentLogoPanel"/>
                                        <TextBlock Text="外观" Style="{StaticResource SectionLabel}" Margin="0,12,0,6"/>
                                        <Grid Margin="0,10,0,3">
                                            <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="54"/><ColumnDefinition Width="52"/></Grid.ColumnDefinitions>
                                            <TextBlock Text="Logo 大小" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                            <TextBlock x:Name="WatermarkLogoScaleValue" Grid.Column="1" Foreground="White" TextAlignment="Right" VerticalAlignment="Center"/>
                                            <Button Grid.Column="2" Style="{StaticResource WatermarkSecondaryButton}" Height="24" Padding="6,0" Margin="6,0,0,0" Tag="LogoScale" Click="WatermarkReset_Click"><TextBlock Text="重置" FontSize="11"/></Button>
                                        </Grid>
                                        <Slider x:Name="WatermarkLogoScaleSlider" Minimum="3" Maximum="50" Value="18" TickFrequency="1" IsSnapToTickEnabled="True" ValueChanged="WatermarkOption_Changed"/>
                                    </StackPanel>

                                    <StackPanel x:Name="SinglePositionPanel" Visibility="Collapsed" Margin="0,12,0,0">
                                        <Grid>
                                            <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="62"/></Grid.ColumnDefinitions>
                                            <TextBlock Text="位置" Style="{StaticResource SectionLabel}" Margin="0" VerticalAlignment="Center"/>
                                            <Button x:Name="ResetSinglePositionBtn" Grid.Column="1" Style="{StaticResource WatermarkSecondaryButton}" Height="28" Margin="0"
                                                    Click="ResetSinglePosition_Click"><TextBlock Text="居中" FontSize="12"/></Button>
                                        </Grid>
                                        <UniformGrid Columns="3" Margin="0,8,0,0">
                                            <Button Style="{StaticResource ToolButton}" Height="30" Margin="0,0,4,4" Tag="TopLeft" Click="WatermarkAnchor_Click"><TextBlock Text="左上" FontSize="12"/></Button>
                                            <Button Style="{StaticResource ToolButton}" Height="30" Margin="2,0,2,4" Tag="TopRight" Click="WatermarkAnchor_Click"><TextBlock Text="右上" FontSize="12"/></Button>
                                            <Button Style="{StaticResource ToolButton}" Height="30" Margin="4,0,0,4" Tag="Center" Click="WatermarkAnchor_Click"><TextBlock Text="居中" FontSize="12"/></Button>
                                            <Button Style="{StaticResource ToolButton}" Height="30" Margin="0,0,4,0" Tag="BottomLeft" Click="WatermarkAnchor_Click"><TextBlock Text="左下" FontSize="12"/></Button>
                                            <Button Style="{StaticResource ToolButton}" Height="30" Margin="2,0,2,0" Tag="BottomRight" Click="WatermarkAnchor_Click"><TextBlock Text="右下" FontSize="12"/></Button>
                                        </UniformGrid>
                                    </StackPanel>

                                    <TextBlock x:Name="WatermarkColorLabel" Text="颜色" Style="{StaticResource SectionLabel}"/>
                                    <WrapPanel x:Name="WatermarkColorPanel">
                                        <Button Style="{StaticResource ColorSwatch}" Background="Black" Tag="Black" Click="WatermarkColor_Click"/>
                                        <Button Style="{StaticResource ColorSwatch}" Background="White" BorderBrush="#FFCCCCCC" Tag="White" Click="WatermarkColor_Click"/>
                                        <Button Style="{StaticResource ColorSwatch}" Background="#FFEA4335" Tag="Red" Click="WatermarkColor_Click"/>
                                        <Button Style="{StaticResource ColorSwatch}" Background="#FF5C8D89" Tag="Teal" Click="WatermarkColor_Click"/>
                                    </WrapPanel>

                                    <WrapPanel Margin="0,12,0,0">
                                        <Button x:Name="BtnBatchWatermark" Style="{StaticResource WatermarkSecondaryButton}"
                                                Click="BtnBatchWatermark_Click"><TextBlock Text="批量加水印"/></Button>
                                    </WrapPanel>

                                    <StackPanel Margin="0,12,0,0">
                                        <TextBlock Text="更多" Style="{StaticResource SectionLabel}" Margin="0,0,0,6"/>
                                        <WrapPanel x:Name="LogoMorePanel" Visibility="Collapsed">
                                            <Button x:Name="WatermarkLogoFlipHBtn" Style="{StaticResource WatermarkSecondaryButton}" Click="WatermarkLogoFlip_Click" Tag="H"><TextBlock Text="水平翻转"/></Button>
                                            <Button x:Name="WatermarkLogoFlipVBtn" Style="{StaticResource WatermarkSecondaryButton}" Click="WatermarkLogoFlip_Click" Tag="V"><TextBlock Text="垂直翻转"/></Button>
                                        </WrapPanel>
                                        <WrapPanel>
                                            <Button Style="{StaticResource WatermarkDangerButton}"
                                                    Click="BtnRemoveWatermark_Click"><TextBlock Text="移除水印"/></Button>
                                        </WrapPanel>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="颜色" Style="{StaticResource SectionLabel}"/>
                        <WrapPanel>
                            <Button x:Name="ClrRedPanel" Style="{StaticResource ColorSwatch}" Background="Red" Tag="Red" Click="Color_Click"/>
                            <Button x:Name="ClrGoldPanel" Style="{StaticResource ColorSwatch}" Background="Gold" Tag="Gold" Click="Color_Click"/>
                            <Button x:Name="ClrLimePanel" Style="{StaticResource ColorSwatch}" Background="Lime" Tag="Lime" Click="Color_Click"/>
                            <Button x:Name="ClrSkyPanel" Style="{StaticResource ColorSwatch}" Background="DeepSkyBlue" Tag="DeepSkyBlue" Click="Color_Click"/>
                            <Button x:Name="ClrBlackPanel" Style="{StaticResource ColorSwatch}" Background="Black" Tag="Black" Click="Color_Click"/>
                            <Button x:Name="ClrWhitePanel" Style="{StaticResource ColorSwatch}" Background="White" BorderBrush="#FFCCCCCC" Tag="White" Click="Color_Click"/>
                            <Button x:Name="ClrCustomPanel" Style="{StaticResource ToolButton}" Width="58" Height="28" Margin="4,3" Padding="4,0"
                                    Click="ColorPicker_Click" ToolTip="色板 / RGB">
                                <TextBlock Text="色板" FontSize="12"/>
                            </Button>
                        </WrapPanel>

                        <TextBlock Text="画笔大小" Style="{StaticResource SectionLabel}"/>
                        <Grid Margin="2,0,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition Width="38"/>
                            </Grid.ColumnDefinitions>
                            <Slider x:Name="ThicknessSlider" Minimum="1" Maximum="20" Value="9"
                                    TickFrequency="1" IsSnapToTickEnabled="True"
                                    ValueChanged="ThicknessSlider_ValueChanged"
                                    PreviewMouseWheel="ThicknessSlider_PreviewMouseWheel"/>
                            <TextBlock x:Name="ThicknessValueText" Grid.Column="1" Text="9"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       VerticalAlignment="Center" TextAlignment="Right"/>
                        </Grid>

                        <TextBlock Text="文字字号" Style="{StaticResource SectionLabel}"/>
                        <UniformGrid Columns="4">
                            <Button x:Name="FontSmallPanelBtn" Style="{StaticResource ToolButton}" Tag="24" Click="FontSize_Click"><TextBlock Text="24"/></Button>
                            <Button x:Name="FontMidPanelBtn" Style="{StaticResource ToolButton}" Tag="36" Click="FontSize_Click"><TextBlock Text="36"/></Button>
                            <Button x:Name="FontLargePanelBtn" Style="{StaticResource ToolButton}" Tag="52" Click="FontSize_Click"><TextBlock Text="52"/></Button>
                            <Button x:Name="FontHugePanelBtn" Style="{StaticResource ToolButton}" Tag="72" Click="FontSize_Click"><TextBlock Text="72"/></Button>
                        </UniformGrid>

                        <TextBlock Text="保存" Style="{StaticResource SectionLabel}"/>
                        <UniformGrid Columns="2" Margin="0,8,0,8">
                            <Button Style="{StaticResource PrimaryButton}" Height="40" Margin="0,0,6,0" Click="MenuSaveAs_Click">
                                <TextBlock Text="另存为"/>
                            </Button>
                            <Button Style="{StaticResource ToolButton}" Height="40" Margin="6,0,0,0"
                                    BorderBrush="{StaticResource BorderBrush1}" BorderThickness="1"
                                    Click="MenuOverwrite_Click">
                                <TextBlock Text="覆盖原图"/>
                            </Button>
                        </UniformGrid>

                        <TextBox x:Name="HistoryCacheText" Visibility="Collapsed"/>
                        <TextBlock x:Name="HistoryCacheInfoText" Visibility="Collapsed"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </DockPanel>
    </Border>
</Window>
