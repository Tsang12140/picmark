<Window x:Class="PicMark.BatchCropPresetNameDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="保存预设" Width="380" SizeToContent="Height"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        FontFamily="Alibaba PuHuiTi 3.0, Alibaba PuHuiTi, Microsoft YaHei UI, Microsoft YaHei, SimHei, Segoe UI">
    <Window.Resources>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#FFF6F7FB"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#FFB8BDC7"/>
        <SolidColorBrush x:Key="FieldBrush" Color="#FF2D2D2D"/>
        <SolidColorBrush x:Key="BorderBrush1" Color="#FF494949"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#FF5265FF"/>
        <SolidColorBrush x:Key="PanelBrush" Color="#FF3A3A3A"/>

        <Style x:Key="LabelText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="FieldBox" TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource FieldBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush1}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <Style x:Key="DarkButton" TargetType="Button">
            <Setter Property="Background" Value="#FF464646"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="#FF555555"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,7"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#FF545454"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#FF3C3C3C"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource DarkButton}">
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>

        <Style x:Key="DarkComboItem" TargetType="{x:Type ComboBoxItem}">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ComboBoxItem}">
                        <Border x:Name="ItemBorder" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#FF464646"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#FF5265FF"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ComboToggleButton" TargetType="{x:Type ToggleButton}">
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="ClickMode" Value="Press"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ToggleButton}">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="#FF6A6A6A"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DarkCombo" TargetType="{x:Type ComboBox}">
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Background" Value="{StaticResource FieldBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush1}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="ItemContainerStyle" Value="{StaticResource DarkComboItem}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ComboBox}">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          Style="{StaticResource ComboToggleButton}"
                                          Background="{TemplateBinding Background}"
                                          BorderBrush="{TemplateBinding BorderBrush}"
                                          BorderThickness="{TemplateBinding BorderThickness}"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"/>
                            <ContentPresenter x:Name="ContentSite"
                                              Margin="10,0,28,0"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Left"
                                              IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"/>
                            <Path HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,11,0"
                                  Fill="{StaticResource TextPrimaryBrush}" Data="M 0 0 L 5 5 L 10 0 Z"/>
                            <Popup x:Name="Popup" Placement="Bottom" AllowsTransparency="True" Focusable="False"
                                   IsOpen="{TemplateBinding IsDropDownOpen}" PopupAnimation="Fade">
                                <Grid Width="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}">
                                    <Border Background="#FF2F2F2F" BorderBrush="#FF5A5A5A" BorderThickness="1" CornerRadius="4">
                                        <Border.Effect>
                                            <DropShadowEffect Color="#FF000000" BlurRadius="16" ShadowDepth="4" Opacity="0.35"/>
                                        </Border.Effect>
                                    </Border>
                                    <ScrollViewer Margin="1" SnapsToDevicePixels="True" MaxHeight="220">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Grid>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Border Background="{StaticResource PanelBrush}" BorderBrush="#FF525252" BorderThickness="1" CornerRadius="10" Padding="20">
            <Border.Effect>
                <DropShadowEffect Color="#FF000000" BlurRadius="24" ShadowDepth="5" Opacity="0.5"/>
            </Border.Effect>
            <StackPanel>
                <Grid Margin="0,0,0,16" Cursor="SizeAll" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                    <TextBlock Text="保存预设" Foreground="{StaticResource TextPrimaryBrush}" FontSize="15" FontWeight="Bold"/>
                </Grid>

                <TextBlock Text="平台" Style="{StaticResource LabelText}" Margin="0,0,0,6"/>
                <ComboBox x:Name="PlatformCombo" Style="{StaticResource DarkCombo}" Margin="0,0,0,8"
                          SelectionChanged="Combo_SelectionChanged">
                    <ComboBoxItem Content="豆包"/>
                    <ComboBoxItem Content="即梦"/>
                    <ComboBoxItem Content="Gemini"/>
                    <ComboBoxItem Content="自定义"/>
                </ComboBox>
                <TextBox x:Name="PlatformCustomBox" Style="{StaticResource FieldBox}" Margin="0,0,0,14"
                         Visibility="Collapsed" TextChanged="CustomBox_TextChanged"/>

                <TextBlock Text="比例" Style="{StaticResource LabelText}" Margin="0,0,0,6"/>
                <ComboBox x:Name="RatioCombo" Style="{StaticResource DarkCombo}" Margin="0,0,0,8"
                          SelectionChanged="Combo_SelectionChanged">
                    <ComboBoxItem Content="1:1"/>
                    <ComboBoxItem Content="4:3"/>
                    <ComboBoxItem Content="3:4"/>
                    <ComboBoxItem Content="16:9"/>
                    <ComboBoxItem Content="9:16"/>
                    <ComboBoxItem Content="16:10"/>
                    <ComboBoxItem Content="10:16"/>
                    <ComboBoxItem Content="自定义"/>
                </ComboBox>
                <TextBox x:Name="RatioCustomBox" Style="{StaticResource FieldBox}" Margin="0,0,0,14"
                         Visibility="Collapsed" TextChanged="CustomBox_TextChanged"/>

                <TextBlock x:Name="PreviewText" Style="{StaticResource LabelText}" Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="12" Margin="0,0,0,16"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Style="{StaticResource DarkButton}" MinWidth="76" Click="Cancel_Click">
                        <TextBlock Text="取消"/>
                    </Button>
                    <Button Style="{StaticResource PrimaryButton}" MinWidth="76" Margin="8,0,0,0" Click="Ok_Click">
                        <TextBlock Text="保存"/>
                    </Button>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Window>
