<Window x:Class="PicMark.BatchCropWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="水印批量裁切" Width="720" Height="880"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        FontFamily="Alibaba PuHuiTi 3.0, Alibaba PuHuiTi, Microsoft YaHei UI, Microsoft YaHei, SimHei, Segoe UI">
    <Window.Resources>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#FFF6F7FB"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#FFB8BDC7"/>
        <SolidColorBrush x:Key="FieldBrush" Color="#FF2D2D2D"/>
        <SolidColorBrush x:Key="BorderBrush1" Color="#FF494949"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#FF5265FF"/>
        <SolidColorBrush x:Key="PanelBrush" Color="#FF3A3A3A"/>

        <Style x:Key="StepLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="HintText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="DarkButton" TargetType="Button">
            <Setter Property="Background" Value="#FF464646"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="#FF555555"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,7"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#FF545454"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#FF3C3C3C"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Background" Value="#FF3A3A3A"/>
                                <Setter Property="Foreground" Value="#FF838383"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource DarkButton}">
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <Style x:Key="SmallDarkButton" TargetType="Button" BasedOn="{StaticResource DarkButton}">
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <Style x:Key="DarkComboItem" TargetType="{x:Type ComboBoxItem}">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ComboBoxItem}">
                        <Border x:Name="ItemBorder" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#FF464646"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#FF5265FF"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ComboToggleButton" TargetType="{x:Type ToggleButton}">
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="ClickMode" Value="Press"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ToggleButton}">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="#FF6A6A6A"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DarkCombo" TargetType="{x:Type ComboBox}">
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Background" Value="{StaticResource FieldBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush1}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="ItemContainerStyle" Value="{StaticResource DarkComboItem}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ComboBox}">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          Style="{StaticResource ComboToggleButton}"
                                          Background="{TemplateBinding Background}"
                                          BorderBrush="{TemplateBinding BorderBrush}"
                                          BorderThickness="{TemplateBinding BorderThickness}"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"/>
                            <ContentPresenter x:Name="ContentSite"
                                              Margin="10,0,24,0"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Left"
                                              IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"/>
                            <Path HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,10,0"
                                  Fill="{StaticResource TextPrimaryBrush}" Data="M 0 0 L 5 5 L 10 0 Z"/>
                            <Popup x:Name="Popup" Placement="Bottom" AllowsTransparency="True" Focusable="False"
                                   IsOpen="{TemplateBinding IsDropDownOpen}" PopupAnimation="Fade">
                                <Grid Width="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}">
                                    <Border Background="#FF2F2F2F" BorderBrush="#FF5A5A5A" BorderThickness="1" CornerRadius="4">
                                        <Border.Effect>
                                            <DropShadowEffect Color="#FF000000" BlurRadius="16" ShadowDepth="4" Opacity="0.35"/>
                                        </Border.Effect>
                                    </Border>
                                    <ScrollViewer Margin="1" SnapsToDevicePixels="True" MaxHeight="200">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Grid>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FileListBox" TargetType="ListBox">
            <Setter Property="Background" Value="#FF2D2D2D"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush1}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
        </Style>
    </Window.Resources>

    <Grid Margin="24">
        <Border Background="{StaticResource PanelBrush}" CornerRadius="8">
            <Border.Effect>
                <DropShadowEffect Color="#FF000000" BlurRadius="24" ShadowDepth="5" Opacity="0.5"/>
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="52"/>
                    <RowDefinition/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                    <TextBlock Text="水印批量裁切" Foreground="{StaticResource TextPrimaryBrush}" FontSize="16" FontWeight="Bold"
                               VerticalAlignment="Center" Margin="22,0,0,0"/>
                    <Button HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,16,0" Width="30" Height="30"
                            Background="Transparent" BorderThickness="0" Foreground="{StaticResource TextPrimaryBrush}"
                            FontSize="18" Click="Close_Click" Cursor="Hand">
                        <TextBlock Text="×" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    </Button>
                </Grid>

                <ScrollViewer Grid.Row="1" Margin="24,0,24,20" VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                <StackPanel>

                    <!-- 第一步：添加文件 -->
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="1. 添加要批量裁切的文件" Style="{StaticResource StepLabel}"/>
                        <Button Grid.Column="1" Style="{StaticResource DarkButton}" Margin="0,0,8,0" Click="AddFiles_Click">
                            <TextBlock Text="添加文件"/>
                        </Button>
                        <Button Grid.Column="2" Style="{StaticResource DarkButton}" Click="AddFolder_Click">
                            <TextBlock Text="添加文件夹"/>
                        </Button>
                    </Grid>

                    <ListBox x:Name="FileListBox" Style="{StaticResource FileListBox}" Height="96"
                             SelectionChanged="FileListBox_SelectionChanged"/>

                    <Grid Margin="0,8,0,22">
                        <Button HorizontalAlignment="Left" Style="{StaticResource SmallDarkButton}" Click="RemoveSelected_Click">
                            <TextBlock Text="移除选中"/>
                        </Button>
                        <TextBlock x:Name="FileCountText" Style="{StaticResource HintText}" HorizontalAlignment="Right"/>
                    </Grid>

                    <!-- 第二步：拖动边距 -->
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="2. 拖动边缘设置裁切范围（按比例自动套用到全部文件）" Style="{StaticResource StepLabel}"
                                   TextWrapping="Wrap"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <TextBlock Text="已保存设置" Style="{StaticResource HintText}" Margin="0,0,6,0"/>
                            <ComboBox x:Name="PresetCombo" Width="110" Style="{StaticResource DarkCombo}"
                                      SelectionChanged="PresetCombo_SelectionChanged" DisplayMemberPath="Name"/>
                            <Button Style="{StaticResource SmallDarkButton}" Margin="6,0,0,0" Click="SavePreset_Click">
                                <TextBlock Text="保存"/>
                            </Button>
                            <Button Style="{StaticResource SmallDarkButton}" Margin="6,0,0,0" Click="DeletePreset_Click">
                                <TextBlock Text="删除"/>
                            </Button>
                        </StackPanel>
                    </Grid>

                    <Border Background="#FF1A1A1A" CornerRadius="6" ClipToBounds="True" Height="380">
                        <Grid x:Name="PreviewHost">
                            <TextBlock x:Name="PreviewEmptyText" Text="请先添加文件，将自动以第一张图作为样图"
                                       Foreground="{StaticResource TextSecondaryBrush}" FontSize="13"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <Canvas x:Name="MarginCanvas" Background="Transparent"
                                    HorizontalAlignment="Center" VerticalAlignment="Center"
                                    MouseLeftButtonDown="MarginCanvas_MouseLeftButtonDown"
                                    MouseMove="MarginCanvas_MouseMove"
                                    MouseLeftButtonUp="MarginCanvas_MouseLeftButtonUp"/>
                        </Grid>
                    </Border>

                    <TextBlock x:Name="MarginInfoText" Style="{StaticResource HintText}" Margin="0,8,0,22"
                               Text="上 0%　下 0%　左 0%　右 0%"/>

                    <!-- 第三步：执行 -->
                    <TextBlock Text="3. 开始批量裁切（结果保存到各文件所在目录的「已裁剪」子文件夹，不修改原图）"
                               Style="{StaticResource StepLabel}" FontSize="13" TextWrapping="Wrap" Margin="0,0,0,10"/>

                    <ProgressBar x:Name="RunProgress" Height="6" Margin="0,0,0,10"
                                 Background="#FF2D2D2D" Foreground="{StaticResource AccentBrush}" BorderThickness="0"/>

                    <Grid>
                        <TextBlock x:Name="StatusText" Style="{StaticResource HintText}" VerticalAlignment="Center"/>
                        <Button x:Name="RunButton" Style="{StaticResource PrimaryButton}" MinWidth="140"
                                HorizontalAlignment="Right" Click="Run_Click">
                            <TextBlock Text="开始批量裁切"/>
                        </Button>
                    </Grid>
                </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</Window>
