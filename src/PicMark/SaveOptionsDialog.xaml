<Window x:Class="PicMark.SaveOptionsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="另存为" Width="735" Height="555"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        FontFamily="Alibaba PuHuiTi 3.0, Alibaba PuHuiTi, Microsoft YaHei UI, Microsoft YaHei, Segoe UI"
        Background="#FF171717">
    <Window.Resources>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#FFF6F7FB"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#FFB8BDC7"/>
        <SolidColorBrush x:Key="FieldBrush" Color="#FF2D2D2D"/>
        <SolidColorBrush x:Key="BorderBrush1" Color="#FF494949"/>
        <Style x:Key="LabelText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="FieldBox" TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource FieldBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush1}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="9,6"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>
        <Style x:Key="DarkCombo" TargetType="ComboBox">
            <Setter Property="Background" Value="{StaticResource FieldBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush1}"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Height" Value="33"/>
        </Style>
        <Style x:Key="DarkButton" TargetType="Button">
            <Setter Property="Background" Value="#FF303030"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush1}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource DarkButton}">
            <Setter Property="Background" Value="#FF5265FF"/>
            <Setter Property="BorderBrush" Value="#FF5265FF"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="18"/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#FF252525" CornerRadius="6" ClipToBounds="True">
            <Grid>
                <Image x:Name="PreviewImage" Stretch="Uniform"/>
                <Border VerticalAlignment="Bottom" Background="#B51F1F1F" Padding="12,9">
                    <TextBlock x:Name="PreviewInfoText" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="72"/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="图片品质" Style="{StaticResource LabelText}"/>
                <ComboBox x:Name="QualityCombo" Grid.Column="1" Style="{StaticResource DarkCombo}" SelectionChanged="AnyOptionChanged">
                    <ComboBoxItem Content="高清" Tag="95" IsSelected="True"/>
                    <ComboBoxItem Content="标准" Tag="82"/>
                    <ComboBoxItem Content="省空间" Tag="68"/>
                </ComboBox>
            </Grid>

            <Grid Grid.Row="1" Margin="0,0,0,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="72"/>
                    <ColumnDefinition Width="82"/>
                    <ColumnDefinition Width="28"/>
                    <ColumnDefinition Width="82"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="82"/>
                    <ColumnDefinition Width="38"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="调整尺寸" Style="{StaticResource LabelText}"/>
                <TextBox x:Name="WidthBox" Grid.Column="1" Style="{StaticResource FieldBox}" TextChanged="SizeBox_TextChanged"/>
                <TextBlock Grid.Column="2" Text="宽" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                <TextBox x:Name="HeightBox" Grid.Column="3" Style="{StaticResource FieldBox}" TextChanged="SizeBox_TextChanged"/>
                <TextBlock Grid.Column="4"/>
                <TextBox x:Name="PercentBox" Grid.Column="5" Style="{StaticResource FieldBox}" TextChanged="PercentBox_TextChanged"/>
                <TextBlock Grid.Column="6" Text="%" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center" HorizontalAlignment="Center"/>
            </Grid>

            <StackPanel Grid.Row="2" Margin="0,0,0,14">
                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <TextBlock Text="目标体积" Style="{StaticResource LabelText}" Width="72"/>
                    <RadioButton x:Name="NoCompressRadio" Content="不压缩" IsChecked="True" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center" Checked="CompressionRadio_Checked"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Width="72"/>
                    <RadioButton x:Name="CompressRadio" Content="压缩至" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center" Checked="CompressionRadio_Checked"/>
                    <TextBox x:Name="TargetSizeBox" Style="{StaticResource FieldBox}" Width="145" Margin="12,0,6,0" IsEnabled="False" TextChanged="AnyTextChanged"/>
                    <ComboBox x:Name="TargetUnitCombo" Style="{StaticResource DarkCombo}" Width="70" IsEnabled="False">
                        <ComboBoxItem Content="KB" IsSelected="True"/>
                        <ComboBoxItem Content="MB"/>
                    </ComboBox>
                </StackPanel>
            </StackPanel>

            <TextBlock Grid.Row="3" x:Name="EstimateText" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" TextWrapping="Wrap"/>

            <Grid Grid.Row="4" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="72"/>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="96"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="格式名称" Style="{StaticResource LabelText}"/>
                <TextBox x:Name="NameBox" Grid.Column="1" Style="{StaticResource FieldBox}"/>
                <ComboBox x:Name="ExtCombo" Grid.Column="2" Style="{StaticResource DarkCombo}" Margin="8,0,0,0" SelectionChanged="AnyOptionChanged">
                    <ComboBoxItem Content=".png"/>
                    <ComboBoxItem Content=".jpg"/>
                    <ComboBoxItem Content=".bmp"/>
                </ComboBox>
            </Grid>

            <Grid Grid.Row="5" Margin="0,0,0,18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="72"/>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="42"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="保存路径" Style="{StaticResource LabelText}"/>
                <TextBox x:Name="PathBox" Grid.Column="1" Style="{StaticResource FieldBox}"/>
                <Button Grid.Column="2" Style="{StaticResource DarkButton}" Margin="8,0,0,0" Padding="8,0" Click="BrowseFolder_Click">
                    <TextBlock Text="□" FontSize="15"/>
                </Button>
            </Grid>

            <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Style="{StaticResource PrimaryButton}" Click="Save_Click" MinWidth="96" Margin="0,0,8,0">保存副本</Button>
                <Button Style="{StaticResource DarkButton}" Click="Cancel_Click" MinWidth="76">取消</Button>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
